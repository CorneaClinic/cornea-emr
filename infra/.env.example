# Docker Compose secrets — copy to infra/.env (never commit)
# Generate: node ../scripts/generate-secrets.js

POSTGRES_PASSWORD=
JWT_SECRET=
SECRETS_ENCRYPTION_KEY=

# Production origins (HTTPS when using Caddy — see docs/PRODUCTION_DEPLOY.md)
CORS_ORIGIN=https://clinic.local
APP_PUBLIC_URL=https://api.local
AUTH_COOKIE_SECURE=true
AUTH_EXPOSE_REFRESH_IN_BODY=false
API_PORT=3000

# SMTP (password reset)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
