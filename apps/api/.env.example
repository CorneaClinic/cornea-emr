# Application
NODE_ENV=development
PORT=3000
API_VERSION=0.2.0

# Database (PostgreSQL)
DATABASE_URL=postgres://cornea:REPLACE_ME@127.0.0.1:5432/cornea_emr_v1
DB_POOL_MAX=20
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=5000

# HTTP — explicit origins only (comma-separated). Never use * in production.
# Include your Cloudflare clinic URL, e.g. https://corneaclinic.visionemr.net
CORS_ORIGIN=http://127.0.0.1:8080,http://localhost:8080

# Authentication — generate with: node ../../scripts/generate-secrets.js
JWT_SECRET=
SECRETS_ENCRYPTION_KEY=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
PASSWORD_RESET_EXPIRES_IN=1h
BCRYPT_ROUNDS=12
AUTH_REFRESH_COOKIE_NAME=cornea_refresh_token
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAME_SITE=lax
APP_PUBLIC_URL=http://127.0.0.1:3000
AUTH_MAX_FAILED_ATTEMPTS=10
AUTH_LOCKOUT_MINUTES=30
AUTH_EXPOSE_REFRESH_IN_BODY=true

# Rate limiting
RATE_LIMIT_LOGIN_WINDOW_MS=900000
RATE_LIMIT_LOGIN_MAX_PER_IP=20
RATE_LIMIT_LOGIN_MAX_PER_EMAIL=10
RATE_LIMIT_RESET_WINDOW_MS=3600000
RATE_LIMIT_RESET_MAX_PER_IP=10

# Seed (first clinic + admin) — set strong password before npm run seed
SEED_CLINIC_NAME=Cornea Clinic
SEED_CLINIC_SLUG=cornea-clinic
SEED_ADMIN_EMAIL=admin@corneaclinic.local
SEED_ADMIN_PASSWORD=
SEED_ADMIN_NAME=System Administrator
ALLOW_PRODUCTION_SEED=false

# Logging (fatal|error|warn|info|debug|trace)
LOG_LEVEL=info

# Clinical media / image storage
MEDIA_STORAGE_PATH=./data/media
MEDIA_MAX_FILE_BYTES=26214400
MEDIA_ALLOWED_MIME_TYPES=image/png,image/jpeg,image/webp,image/svg+xml,application/pdf

# SMTP (password reset emails — required in production for self-service reset)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=