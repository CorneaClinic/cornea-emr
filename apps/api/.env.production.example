# Live cloud PostgreSQL (DigitalOcean) — DO NOT COMMIT.
# Copy to .env.production and fill in from:
#   DigitalOcean -> Databases -> your DB -> Connection details
#
# IMPORTANT: For backups from the clinic PC, use PUBLIC network host:
#   db-pgsql-....ondigitalocean.com
# Do NOT use private-db-pgsql-.... (VPC-only; times out from local PC).
# Add your PC's public IP under Database -> Trusted sources.
#
# Example (replace USER, PASSWORD, and public host):
DATABASE_URL=postgresql://Corneaclinic:PASSWORD@db-pgsql-sgp1-xxxxx.ondigitalocean.com:25060/defaultdb?sslmode=require
